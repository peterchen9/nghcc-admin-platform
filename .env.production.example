APP_NAME=北門行政作業平台
APP_ENV=production
APP_PORT=26001

COMPOSE_PROJECT_NAME=nghcc-admin-platform

DATABASE_URL=mysql://nghcc_admin:請改成正式密碼@db:3306/nghcc_admin
DB_HOST=db
DB_PORT=3306
DB_EXTERNAL_PORT=26003
DB_NAME=nghcc_admin
DB_USER=nghcc_admin
DB_PASSWORD=請改成正式密碼
DB_ROOT_PASSWORD=請改成正式 root 密碼

UPLOAD_DIR=/app/media

JWT_SECRET=請改成足夠長的隨機字串
SESSION_SECRET=請改成足夠長的隨機字串
DJANGO_SECRET_KEY=請改成足夠長的-django-secret-key

DEBUG=False
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=192.168.16.240,localhost
CSRF_TRUSTED_ORIGINS=http://192.168.16.240:26001
ENABLE_CSRF_PROTECTION=False
ENABLE_MENU_PERMISSION_ENFORCEMENT=False
API_PERMISSION_MODE=off

# 目前 .240 使用 HTTP，因此先保留 False。
# 若未來改成 HTTPS，請改為：
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# CSRF_TRUSTED_ORIGINS=https://正式網域
# ENABLE_CSRF_PROTECTION=True
# 但需先通過 csrf tests 與人工驗證。
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_HTTPONLY=False
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=SAMEORIGIN

UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx
UPLOAD_STRICT_MIME_CHECK=False
