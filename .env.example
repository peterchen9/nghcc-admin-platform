APP_NAME=北門行政作業平台
APP_ENV=local
APP_PORT=26001

COMPOSE_PROJECT_NAME=nghcc-admin-platform

FRONTEND_PORT=26001
BACKEND_PORT=26002

DATABASE_URL=mysql://nghcc_admin:change_me_password@db:3306/nghcc_admin_platform
DB_HOST=db
DB_PORT=3306
DB_EXTERNAL_PORT=26003
DB_NAME=nghcc_admin_platform
DB_USER=nghcc_admin
DB_PASSWORD=change_me_password
DB_ROOT_PASSWORD=change_me_root_password

UPLOAD_DIR=/app/uploads
JWT_SECRET=請改成足夠長的隨機字串
SESSION_SECRET=請改成足夠長的隨機字串
DJANGO_SECRET_KEY=請改成足夠長的-django-secret-key
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.16.240
CSRF_TRUSTED_ORIGINS=http://localhost:26001,http://127.0.0.1:26001,http://192.168.16.240:26001
