APP_NAME=北門行政作業平台
APP_ENV=local
APP_PORT=26001
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

COMPOSE_PROJECT_NAME=nghcc-admin-platform

DATABASE_URL=mysql://nghcc_admin:change_me_password@db:3306/nghcc_admin
DB_HOST=db
DB_PORT=3306
DB_EXTERNAL_PORT=26003
DB_NAME=nghcc_admin
DB_USER=nghcc_admin
DB_PASSWORD=change_me_password
DB_ROOT_PASSWORD=change_me_root_password

UPLOAD_DIR=/app/media

JWT_SECRET=請改成足夠長的隨機字串
SESSION_SECRET=請改成足夠長的隨機字串
DJANGO_SECRET_KEY=請改成足夠長的-django-secret-key
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:26001

SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_HTTPONLY=False
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=SAMEORIGIN

UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx
