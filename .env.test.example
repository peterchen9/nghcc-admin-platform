DJANGO_SETTINGS_MODULE=nads26.settings
DATABASE_URL=mysql://nghcc_admin:change_me_password@db:3306/nghcc_admin
TEST_DATABASE_URL=mysql://nghcc_admin:change_me_password@db:3306/nghcc_admin
SECRET_KEY=local-test-secret-key
DEBUG=False
DJANGO_SECRET_KEY=local-test-secret-key
DJANGO_DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:26001

SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_HTTPONLY=False
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=SAMEORIGIN

UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx
UPLOAD_STRICT_MIME_CHECK=False

# Smoke test login credentials.
# Do not commit real passwords in .env files.
TEST_USERNAME=
TEST_PASSWORD=
TEST_USERNAME_SECONDARY=
TEST_PASSWORD_SECONDARY=
TEST_ADMIN_USERNAME=
TEST_ADMIN_PASSWORD=
